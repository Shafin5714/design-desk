# Global Environment Variables Template

# 1. Database
# Local MongoDB connection string matching the docker-compose setup
MONGO_URI=mongodb://admin:password@localhost:27017/design-desk?authSource=admin

# 2. Authentication (Auth Service)
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES_IN=7d

# 3. Media & Assets (Asset Service)
# Create an account at imagekit.io to get these credentials
IMAGEKIT_PUBLIC_KEY=your_public_key
IMAGEKIT_PRIVATE_KEY=your_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id/

# 4. API Gateway
PORT=4000
